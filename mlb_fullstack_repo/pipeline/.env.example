SUPABASE_INGEST_URL=https://<your-vercel-domain>.vercel.app/api/ingest/projections
PIPELINE_INGEST_SECRET=<random-secret-min-32-chars>

# Optional: used when pulling Kaggle historical odds datasets.
KAGGLE_USERNAME=<your-kaggle-username>
KAGGLE_KEY=<your-kaggle-api-key>

# Supabase direct access, if pipeline writes directly instead of through the ingest API.
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>
